---
interface Props {
	src: string;
	alt: string;
	caption?: string;
	fit?: "cover" | "contain";
	aspectRatio?: string;
	class?: string;
	imgClass?: string;
}

const {
	src,
	alt,
	caption,
	fit = "cover",
	aspectRatio = "1920/947",
	class: className = "",
	imgClass = "",
} = Astro.props;

const uid = crypto.randomUUID();
---

<figure class="m-0">
	<button
		type="button"
		class:list={[
			"media-viewer-trigger group relative block w-full cursor-zoom-in overflow-hidden",
			fit === "cover" && "aspect-(--mv-aspect)",
			className,
		]}
		style={fit === "cover" ? `--mv-aspect: ${aspectRatio}` : undefined}
		data-viewer-target={uid}
		aria-label={`View ${alt} full size`}
	>
		<img
			src={src}
			alt={alt}
			loading="lazy"
			class:list={[
				fit === "cover"
					? "absolute inset-0 h-full w-full object-cover object-center"
					: "h-auto w-full",
				imgClass,
			]}
		/>
		<span
			class="bg-bg/0 group-hover:bg-bg/40 pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition-all duration-150 group-hover:opacity-100"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="text-text size-8 scale-90 transition-transform duration-150 group-hover:scale-100"
			>
				<circle cx="11" cy="11" r="8"></circle>
				<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				<line x1="11" y1="8" x2="11" y2="14"></line>
				<line x1="8" y1="11" x2="14" y2="11"></line>
			</svg>
		</span>
	</button>
	{
		caption && (
			<figcaption class="text-text-muted mt-2 text-sm">
				{caption}
			</figcaption>
		)
	}
</figure>

<dialog
	id={`viewer-${uid}`}
	class="media-viewer-dialog backdrop:bg-bg/90 fixed inset-0 z-9999 m-0 h-dvh max-h-none w-dvw max-w-none border-none bg-transparent p-0 open:flex"
>
	<div
		class="media-viewer-stage relative flex h-dvh w-dvw items-center justify-center overflow-hidden p-6 sm:p-10 md:p-16"
	>
		<button
			type="button"
			class="media-viewer-close text-text hover:text-primary bg-surface/80 border-border absolute top-4 right-4 z-10 grid size-10 cursor-pointer place-items-center border"
			aria-label="Close"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="size-5"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
		<img
			src={src}
			alt={alt}
			class="media-viewer-img max-h-full max-w-full cursor-zoom-in touch-none object-contain shadow-2xl will-change-transform select-none"
			draggable="false"
		/>
	</div>
</dialog>

<script>
	function setupViewer(trigger: HTMLButtonElement) {
		const targetId = trigger.dataset.viewerTarget;
		const dialog = document.getElementById(
			`viewer-${targetId}`,
		) as HTMLDialogElement | null;
		if (!dialog) return;

		if (dialog.parentElement !== document.body) {
			document.body.appendChild(dialog);
		}

		const img = dialog.querySelector(
			".media-viewer-img",
		) as HTMLImageElement;
		const closeBtn = dialog.querySelector(
			".media-viewer-close",
		) as HTMLButtonElement;

		let scale = 1;
		let panX = 0;
		let panY = 0;
		let isPanning = false;
		let startX = 0;
		let startY = 0;

		const applyTransform = () => {
			img.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
			img.style.cursor = scale > 1 ? "grab" : "zoom-in";
		};

		const reset = () => {
			scale = 1;
			panX = 0;
			panY = 0;
			applyTransform();
		};

		const openViewer = () => {
			dialog.showModal();
			document.documentElement.style.overflow = "hidden";
			reset();
		};

		const closeViewer = () => {
			dialog.close();
			document.documentElement.style.overflow = "";
		};

		trigger.addEventListener("click", openViewer);
		closeBtn.addEventListener("click", closeViewer);

		dialog.addEventListener("click", (e) => {
			if (
				e.target !== img &&
				e.target !== closeBtn &&
				!closeBtn.contains(e.target as Node)
			) {
				closeViewer();
			}
		});

		dialog.addEventListener("close", () => {
			document.documentElement.style.overflow = "";
		});

		img.addEventListener("click", (e) => {
			if (isPanning) return;
			e.stopPropagation();
			if (scale === 1) {
				scale = 2.5;
			} else {
				scale = 1;
				panX = 0;
				panY = 0;
			}
			applyTransform();
		});

		img.addEventListener(
			"wheel",
			(e) => {
				e.preventDefault();
				const delta = -e.deltaY * 0.0015;
				const next = Math.min(5, Math.max(1, scale + delta));
				scale = next;
				if (scale === 1) {
					panX = 0;
					panY = 0;
				}
				applyTransform();
			},
			{ passive: false },
		);

		img.addEventListener("mousedown", (e) => {
			if (scale === 1) return;
			isPanning = true;
			startX = e.clientX - panX;
			startY = e.clientY - panY;
			img.style.cursor = "grabbing";
		});

		window.addEventListener("mousemove", (e) => {
			if (!isPanning) return;
			panX = e.clientX - startX;
			panY = e.clientY - startY;
			applyTransform();
		});

		window.addEventListener("mouseup", () => {
			if (!isPanning) return;
			isPanning = false;
			img.style.cursor = scale > 1 ? "grab" : "zoom-in";
		});

		let touchStartDist = 0;
		let touchStartScale = 1;

		img.addEventListener("touchstart", (e) => {
			if (e.touches.length === 2) {
				const dx = e.touches[0].clientX - e.touches[1].clientX;
				const dy = e.touches[0].clientY - e.touches[1].clientY;
				touchStartDist = Math.hypot(dx, dy);
				touchStartScale = scale;
			} else if (e.touches.length === 1 && scale > 1) {
				isPanning = true;
				startX = e.touches[0].clientX - panX;
				startY = e.touches[0].clientY - panY;
			}
		});

		img.addEventListener(
			"touchmove",
			(e) => {
				if (e.touches.length === 2) {
					e.preventDefault();
					const dx = e.touches[0].clientX - e.touches[1].clientX;
					const dy = e.touches[0].clientY - e.touches[1].clientY;
					const dist = Math.hypot(dx, dy);
					scale = Math.min(
						5,
						Math.max(1, touchStartScale * (dist / touchStartDist)),
					);
					applyTransform();
				} else if (e.touches.length === 1 && isPanning) {
					panX = e.touches[0].clientX - startX;
					panY = e.touches[0].clientY - startY;
					applyTransform();
				}
			},
			{ passive: false },
		);

		img.addEventListener("touchend", () => {
			isPanning = false;
		});
	}

	function init() {
		document
			.querySelectorAll<HTMLButtonElement>(".media-viewer-trigger")
			.forEach((trigger) => {
				if (trigger.dataset.viewerBound) return;
				trigger.dataset.viewerBound = "true";
				setupViewer(trigger);
			});
	}

	init();
	document.addEventListener("astro:page-load", init);
</script>
