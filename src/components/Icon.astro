---
interface Props {
  src: string;
  size?: number | string;
  class?: string;
  title?: string;
}

const {
  src,
  size = 24,
  class: className = "",
  title,
} = Astro.props;
---

<span
  class={className}
  style={`width:${size}px;height:${size}px;`}
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
  aria-label={title}
  set:html={src}
/>