---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import { ArrowLeft } from "@lucide/astro";
import { useTranslations } from "@/i18n/utils";

export async function getStaticPaths() {
	const languages = ["en", "de"];

	return languages.map((lang) => ({
		params: { lang },
	}));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
	.filter((post) => post.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
	<div class="flex flex-row gap-10">
		<a
			class="text-text-muted hover:text-primary mb-5 inline-flex items-center gap-2"
			href={`/`}
		>
			<ArrowLeft size={16} />
			<span>cd ../</span>
		</a>
	</div>

	<section class="flex w-full flex-col gap-5">
		<input
			id="search"
			type="search"
			placeholder={t('button.search')}
			class="bg-bg border-border text-text mb-6 w-full border-2 px-4 py-3 outline-none"
		/>

		<div id="posts" class="flex flex-col gap-4">
			{
				posts.map((post) => {
					const slug = post.id.replace(`${lang}/`, "");

					const searchable = [
						post.data.title,
						...(post.data.tags ?? []),
					]
						.join(" ")
						.toLowerCase();

					return (
						<a
							href={`/${lang}/blog/${slug}`}
							class="blog-post border-border bg-bg hover:border-primary block border-2 p-5 transition-colors"
							data-search={searchable}
						>
							<h2 class="text-text text-xl font-bold">
								{post.data.title}
							</h2>

							{post.data.tags?.length > 0 && (
								<div class="mt-3 flex flex-wrap gap-2">
									{post.data.tags.map((tag: string) => (
										<span class="border-border text-primary border px-2 py-1 text-xs">
											#{tag}
										</span>
									))}
								</div>
							)}

							{post.data.description && (
								<p class="text-text-muted mt-3">
									{post.data.description}
								</p>
							)}
						</a>
					);
				})
			}
		</div>
	</section>

	<script>
		const input = document.querySelector<HTMLInputElement>("#search");
		const posts = [...document.querySelectorAll<HTMLElement>(".blog-post")];

		input?.addEventListener("input", () => {
			const query = input.value.toLowerCase().trim();

			for (const post of posts) {
				const searchable = post.dataset.search ?? "";

				post.style.display = searchable.includes(query) ? "" : "none";
			}
		});
	</script>
</Layout>
